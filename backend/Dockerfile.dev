FROM node:22-alpine

WORKDIR /app

# Copia os arquivos de configuração da raiz para instalar dependências do monorepo
COPY package*.json ./
COPY backend/package*.json ./backend/

# Instala todas as dependências (incluindo devDependencies para o tsx watch)
RUN npm install

# Copia o restante do código do backend
COPY backend ./backend

# Expõe a porta do backend
EXPOSE 3001

# Comando para rodar em modo desenvolvimento com Hot Reload
CMD ["npm", "run", "dev", "-w", "backend"]
