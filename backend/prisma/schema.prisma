// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String                     @id @default(uuid())
  email              String                     @unique
  passwordHash       String
  emailVerified      Boolean                    @default(false) @map("email_verified")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")
  nicks              Nick[]
  badges             UserBadge[]
  verificationTokens EmailVerificationToken[]

  @@map("users")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model Nick {
  id          String         @id @default(uuid())
  name        String
  userId      String         @map("user_id")
  user        User           @relation(fields: [userId], references: [id])
  catalogueId String?        @map("catalogue_id")
  catalogue   NickCatalogue? @relation(fields: [catalogueId], references: [id])
  aura        String?
  score       Int            @default(100)
  expiresAt   DateTime       @map("expires_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  posts       Post[]
  votes       Vote[]
  comments    Comment[]
  reportsMade Report[]

  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@map("nicks")
}

model Post {
  id        String    @id @default(uuid())
  content   String
  tag       String?
  nickId    String    @map("nick_id")
  nick      Nick      @relation(fields: [nickId], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")
  factCount Int       @default(0) @map("fact_count")
  ficCount  Int       @default(0) @map("fic_count")
  votes     Vote[]
  comments  Comment[]
  reports   Report[]

  @@index([createdAt])
  @@map("posts")
}

model Vote {
  id        String   @id @default(uuid())
  isReal    Boolean  @map("is_real")
  nickId    String   @map("nick_id")
  nick      Nick     @relation(fields: [nickId], references: [id])
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([nickId, postId])
  @@map("votes")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  nickId    String   @map("nick_id")
  nick      Nick     @relation(fields: [nickId], references: [id])
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([postId])
  @@map("comments")
}

model NickCatalogue {
  id       String  @id @default(uuid())
  name     String  @unique
  category String?
  isActive Boolean @default(true)
  nicks    Nick[]

  @@index([isActive])
  @@map("nick_catalogue")
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  icon        String      // Emoji ou nome do ícone Lucide
  users       UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  badgeId   String   @map("badge_id")
  badge     Badge    @relation(fields: [badgeId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Report {
  id             String   @id @default(uuid())
  reason         String
  status         String   @default("pending") // pending, resolved, rejected
  postId         String   @map("post_id")
  post           Post     @relation(fields: [postId], references: [id])
  reporterNickId String   @map("reporter_nick_id")
  reporterNick   Nick     @relation(fields: [reporterNickId], references: [id])
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("reports")
}
