# Database — usar db:5432 dentro do Docker, localhost:5434 fora
DATABASE_URL="postgresql://user:password@db:5432/subsolo?schema=public"
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=subsolo

# Backend
PORT=3001
# OBRIGATÓRIO: gere um valor forte com: openssl rand -hex 32
JWT_SECRET=troque_por_um_segredo_forte_aqui
FRONTEND_URL=http://localhost:3000
# Gmail — conta dedicada para envio de e-mails
GMAIL_USER=seu@gmail.com
GMAIL_APP_PASSWORD=app_password_de_16_chars

# Purge Job — dias até deletar permanentemente posts removidos (padrão: 30)
PURGE_AFTER_DAYS=30

# Frontend
VITE_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
